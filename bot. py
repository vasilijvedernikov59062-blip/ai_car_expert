2import logging
import os
from typing import Any

import requests
from telegram import Update
from telegram.ext import Application, CommandHandler, ContextTypes, MessageHandler, filters

logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s | %(levelname)s | %(name)s | %(message)s',
)
logger = logging.getLogger('car_analyzer_bot')

# Можно задать токен напрямую в TOKEN или через переменную окружения TELEGRAM_BOT_TOKEN.
TOKEN = '8575799416:AAEhv0Q7fnBw9ppIZ_cGjcnL4qjI9PtUcPY'
ANALYZE_API_URL = os.getenv('ANALYZE_API_URL', 'http://127.0.0.1:8000/analyze-car')


def parse_car_text(text: str) -> dict[str, Any]:
    """Parse user text into analyze-car payload.

    Supported format:
    <brand> <model> <year> <mileage>

    Example:
    Toyota Camry 2018 95000
    """
    parts = text.split()
    if len(parts) < 4:
        raise ValueError(
            'Нужен формат: <brand> <model> <year> <mileage>. '
            'Пример: Toyota Camry 2018 95000'
        )

    brand = parts[0]
    model = ' '.join(parts[1:-2])
    if not model:
        raise ValueError('Не удалось распознать model. Пример: Toyota Camry 2018 95000')

    try:
        year = int(parts[-2])
        mileage = int(parts[-1])
    except ValueError as exc:
        raise ValueError('Поля year и mileage должны быть целыми числами.') from exc

    return {
        'brand': brand,
        'model': model,
        'year': year,
        'mileage': mileage,
    }


async def start(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    await update.message.reply_text(
        'Привет! 👋\n'
        'Я анализирую авто через endpoint /analyze-car.\n\n'
        'Отправь данные в формате:\n'
        '<brand> <model> <year> <mileage>\n\n'
        'Пример:\n'
        'Toyota Camry 2018 95000'
    )


async def handle_text(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    text = (update.message.text or '').strip()
    if not text:
        await update.message.reply_text('Пожалуйста, отправь данные об авто текстом.')
        return

    logger.info('Received user text: %s', text)

    try:
        payload = parse_car_text(text)
        response = requests.post(ANALYZE_API_URL, json=payload, timeout=10)
        response.raise_for_status()
        data = response.json()

        decision = data.get('decision', 'n/a')
        reason = data.get('reason', 'n/a')
        estimated_price = data.get('estimated_price', 'n/a')
        summary = data.get('summary', 'n/a')

        message = (
            '📊 Результат анализа:\n\n'
            f"• Авто: {payload['brand']} {payload['model']} ({payload['year']})\n"
            f'• Решение: {decision}\n'
            f'• Причина: {reason}\n'
            f'• Оценка цены: ${estimated_price}\n\n'
            f'🧠 Коротко: {summary}'
        )
        await update.message.reply_text(message)
    except ValueError as exc:
        await update.message.reply_text(f'Ошибка формата: {exc}')
    except requests.RequestException as exc:
        logger.exception('API call failed')
        await update.message.reply_text(
            'Не удалось получить ответ от сервиса анализа. '
            'Проверь, что API запущено и попробуй ещё раз.\n'
            f'Техническая ошибка: {exc}'
        )


def main() -> None:
    if not TOKEN:
        raise RuntimeError('Set TOKEN in bot.py or TELEGRAM_BOT_TOKEN environment variable')

    logger.info('Starting bot with API URL: %s', ANALYZE_API_URL)
    app = Application.builder().token(TOKEN).build()
    app.add_handler(CommandHandler('start', start))
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_text))
    app.run_polling()


if __name__ == '__main__':
    main()
